# ===== AI 配置 =====

# DeepSeek（推荐，国产，便宜）
AI_API_KEY=sk-your-deepseek-api-key
AI_BASE_URL=https://api.deepseek.com/v1
AI_MODEL=deepseek-chat

# OpenAI 兼容格式（可选，如果使用 OpenAI 或其他兼容服务）
# OPENAI_API_KEY=sk-your-openai-api-key
# OPENAI_BASE_URL=https://api.openai.com/v1

# ===== 数据库配置 =====
# 如果要在 Vercel 上部署，请选择以下任一方案：

# ---------- 方案 1：Neon Postgres（推荐） ----------
# 创建数据库：https://neon.tech
# DATABASE_URL=postgresql://user:password@hostname:5432/dbname

# ---------- 方案 2：Supabase ----------
# 创建数据库：https://supabase.com
# DATABASE_URL=postgresql://postgres:[YOUR-PASSWORD]@[YOUR-PROJECT-REF].supabase.co:5432/postgres

# ---------- 方案 3：Turso ----------
# 创建数据库：https://turso.tech
# DATABASE_URL=libsql://your-db-url.turso.io
# TURSO_AUTH_TOKEN=your-auth-token

# ===== 本地开发（默认） =====
# 如果没有配置 DATABASE_URL，项目会自动使用 SQLite
# SQLite 适合本地开发，数据保存在 ./data/app.db
